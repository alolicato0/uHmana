{
  "expo": {
    "name": "uHmana",
    "slug": "uhmana",
    "version": "0.3.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "uhmana",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f5e4da30-71e1-44cb-b305-856c1a920d91",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.uhmana.uhmana",
      "infoPlist": {
        "NSCameraUsageDescription": "uHmana usa la fotocamera per analizzare immagini di sintomi e referti.",
        "NSPhotoLibraryUsageDescription": "uHmana accede alle foto per analisi AI e archivio cartella clinica."
      }
    },
    "android": {
      "package": "app.uhmana.uhmana",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@react-native-google-signin/google-signin",
      [
        "expo-image-picker",
        {
          "photosPermission": "uHmana accede alle foto per analisi AI e archivio.",
          "cameraPermission": "uHmana usa la fotocamera per analizzare sintomi."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#00B5A6",
          "defaultChannel": "reminders"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo-full.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF",
          "dark": {
            "backgroundColor": "#0F1419"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f5e4da30-71e1-44cb-b305-856c1a920d91"
      }
    },
    "owner": "albertoct"
  }
}
