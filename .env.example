# =============================================================================
# uHmana — Variabili d'ambiente
# Copia questo file in `.env` e compila i valori.
# In Expo, le variabili che inizia con EXPO_PUBLIC_ sono accessibili sul client.
# Per i secret veri (es. OPENROUTER_API_KEY) usare il backend Render.
# =============================================================================

# -- Clerk Auth (dashboard.clerk.com → API Keys) -----------------------------
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -- Backend Render (URL del nostro server Node ospitato su Render) ----------
EXPO_PUBLIC_API_URL=https://uhmana-api.onrender.com

# -- OpenRouter (USARE SOLO LATO BACKEND, non esporre mai al client) ---------
# Il client chiama il nostro backend, che a sua volta chiama OpenRouter.
# Queste variabili vanno settate nei "Environment Variables" del servizio Render.
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL_PRIMARY=google/gemini-2.0-flash-exp:free
OPENROUTER_MODEL_FALLBACK=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_MODEL_VISION=google/gemini-2.0-flash-exp:free

# -- (Opzionale) sviluppo locale puntando OpenRouter direttamente -------------
# Solo per testing rapido senza backend. Mai in produzione.
EXPO_PUBLIC_DIRECT_OPENROUTER=false
