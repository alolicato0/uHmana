# =============================================================================
# uHmana Backend — Variabili d'ambiente
# Da settare nei "Environment" su Render (dashboard.render.com).
# In locale: copia in `.env` (non commitarlo mai).
# =============================================================================

# Porta del server (Render la imposta automaticamente — non toccare)
PORT=8787

# Origini consentite per CORS (separati da virgola).
# In dev: lascia "*". In prod: solo i tuoi domini Expo + web.
CORS_ORIGINS=*

# -- MongoDB Atlas -----------------------------------------------------------
# cloud.mongodb.com → Connect → Drivers → copia la connection string
# Sostituisci <password> con la password del tuo DB user.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/uhmana?retryWrites=true&w=majority

# -- Clerk (dashboard.clerk.com → API Keys) ----------------------------------
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -- OpenRouter (openrouter.ai → Keys) ---------------------------------------
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL_PRIMARY=google/gemini-2.0-flash-exp:free
OPENROUTER_MODEL_FALLBACK=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_MODEL_VISION=google/gemini-2.0-flash-exp:free

# Per il leaderboard OpenRouter (puoi tenere così)
APP_REFERER=https://uhmana.app
APP_TITLE=uHmana
